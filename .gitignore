# Environment variables — never commit API keys to version control
.env

# Python bytecode — generated automatically, not needed in version control
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environment folders
venv/
.venv/
env/

# Local storage — generated at runtime on each machine
storage/chromadb/
storage/llm_cache/

# Real bank statement dataset — contains PII, never commit
Bank-statements-dataset/

# Streamlit dev/testing interface — local tool only, not production code
app.py

# Upload folder — investigator files are not part of the codebase
uploads/

# Output files — generated reports and graphs
outputs/reports/
outputs/graphs/

# Oversized generated ground-truth artifact; requires Git LFS if it must be shared.
Bank-statements-dataset 2/Bank-statements-dataset/ground_truth_artifacts/ground_truth.json

# Persisted extraction runs — contain REAL (de-anonymised) transaction data.
# Generated locally on each run; must never be committed.
outputs/extractions/

# Generated analysis artifacts — SQLite DBs + results JSON, multi-GB, individual files
# exceed GitHub's 100MB limit. Regenerated by every analysis run; never committed.
analysis/outputs/

# Reporting virtualenv (Playwright/Chromium, ~165MB) — recreated per machine via SETUP.
.report_venv/

# Pytest cache and frontend build output
.pytest_cache/
frontend/dist/
tejas s/frontend/dist/

# Local-only verification viewer & dev tools — internal demo aids, never pushed.
tools/

# macOS metadata files
.DS_Store

# IDE project files
.vscode/
.idea/
*.swp
chroma_store/

# Synthetic test dataset and synthetic dev artifacts
synthetic_test_data/
analysis/synthetic_cases/
scripts/validate_synthetic_patterns.py
tmp/

# Internal planning and dev-phase documents (never push)
ZDOCUMENTS/
DELIVERABLES.md
EVALUATION_NOTES.md
INVESTIGATION_GRAPH_PLAN.md
analysis.md
extraction.md
reportgen.md
random.txt
"analysis phase cidecode hackathon/"

# Personal/accidental files
*.mp4
!frontend/public/*.mp4
